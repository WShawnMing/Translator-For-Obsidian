{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2020"],
    "allowJs": false,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "importHelpers": false,
    "baseUrl": ".",
    "types": ["node"],
    "inlineSourceMap": true,
    "inlineSources": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
