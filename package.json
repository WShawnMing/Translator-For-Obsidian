{
  "name": "translator-for-obsidian",
  "version": "0.1.11",
  "description": "Obsidian plugin for translating selected text with a hover orb and draggable popup.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "translation",
    "openai-compatible"
  ],
  "license": "MIT",
  "devDependencies": {
    "@codemirror/view": "^6.36.7",
    "@types/node": "^20.17.30",
    "esbuild": "^0.25.2",
    "obsidian": "latest",
    "typescript": "^5.8.3"
  }
}
